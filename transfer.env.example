# Шаблон .env для поставки без маркетплейсов и без ЮKassa (репозиторий передачи).
# Скопируйте в backend/.env и заполните секреты.

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/ikamdocs
SECRET_KEY=
ALLOWED_ORIGINS=https://your-domain.ru
STORAGE_PATH=/var/ikamdocs/storage
ENCRYPTION_KEY=
REDIS_URL=redis://localhost:6379/0

# Отключить OAuth маркетплейсов (Shopify/WB/Ozon) и UI/API синхронизации
FEATURE_MARKETPLACE_OAUTH=false

# Отключить оплату ЮKassa, webhook и страницу оплаты в кабинете
FEATURE_YOOKASSA=false

# Ключи маркетплейсов и ЮKassa не обязательны при false выше
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
