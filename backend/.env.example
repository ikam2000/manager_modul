# Database (PostgreSQL на российском сервере)
DATABASE_URL=postgresql+asyncpg://ikamdocs:PASSWORD@localhost:5432/ikamdocs

# JWT
SECRET_KEY=your-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Реквизиты продавца для счёта (по умолчанию — ИП Каменев)
# INVOICE_SELLER_NAME=...
# INVOICE_SELLER_INN=...
# и т.д. — опционально, если нужны другие реквизиты

# ЮKassa (карта, СБП)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://ikamdocs.ru/cabinet/payment/return

# DaData (поиск по ИНН: поставщики, производители, заказчики)
DADATA_API_KEY=
DADATA_SECRET=

# OAuth интеграции (Shopify, Wildberries, Ozon — при наличии провайдер отображается в Интеграциях)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
WILDBERRIES_CLIENT_ID=
WILDBERRIES_CLIENT_SECRET=
OZON_CLIENT_ID=
OZON_CLIENT_SECRET=
BASE_URL=https://ikamdocs.ru


# Redis
REDIS_URL=redis://localhost:6379/0

# Email (SMTP Timeweb): письма от zero@ikamdocs.ru — регистрация, сброс пароля
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=zero@ikamdocs.ru
SMTP_PASSWORD=
EMAIL_FROM=zero@ikamdocs.ru
EMAIL_FROM_NAME=ikamdocs
LANDING_RECIPIENTS=ikam2000@yandex.ru,zero@ikamdocs.ru

# OpenAI (опционально — для AI-функций: распознавание, умный поиск)
OPENAI_API_KEY=

# Функциональные флаги (см. transfer.env.example для поставки без маркетплейсов и без ЮKassa)
# FEATURE_MARKETPLACE_OAUTH=true
# FEATURE_YOOKASSA=true

# App
DEBUG=false
ALLOWED_ORIGINS=https://ikamdocs.ru,https://www.ikamdocs.ru

# Хранение документов (путь на сервере)
STORAGE_PATH=/var/ikamdocs/storage
ENCRYPTION_KEY=base64-encoded-32-bytes-key
